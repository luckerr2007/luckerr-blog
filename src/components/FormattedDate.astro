---
interface Props {
    date: Date;
}

const { date } = Astro.props;
const isValidDate = date && !Number.isNaN(date.valueOf());
---

{
    isValidDate && (
        <time datetime={date.toISOString()}>
            {`${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日`}
        </time>
    )
}
